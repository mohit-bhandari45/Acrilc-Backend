# Server
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb://127.0.0.1:27017/acrilc

# Auth / Sessions
JWT_SECRET=change-me-to-a-long-random-secret
SESSION_SECRET=change-me-to-a-long-random-secret
ADMIN_EMAIL=admin@example.com

# Redis / BullMQ
REDIS_URL=redis://127.0.0.1:6379

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://your-backend-domain.com/auth/google/callback
BACKEND_URL=https://your-backend-domain.com
BACKEND_URL_LOCAL=http://localhost:8000

# Frontend URLs
FRONTEND_URL=https://acrilc-web.vercel.app
FRONTEND_URL_LOCAL=http://localhost:3000
CORS_ORIGINS=https://acrilc-web.vercel.app,http://localhost:3000

# Email
EMAIL_USER=your-gmail-address@gmail.com
EMAIL_PASS=your-gmail-app-password
EMAIL_FROM=Acrilc Team <your-gmail-address@gmail.com>

# Frontend URL used in email links
FRONTEND_URL=https://acrilc-web.vercel.app
FRONTEND_URL_LOCAL=http://localhost:3000
